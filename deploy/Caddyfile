# WOO Buddy — Caddy config for production
#
# Layout:
#   woobuddy.nl          → SvelteKit node server (frontend:3000)
#     /api/*             → FastAPI (api:8000)
#   www.woobuddy.nl      → 301 to https://woobuddy.nl{uri}
#
# TLS certificates are obtained automatically from Let's Encrypt on first
# start; Caddy persists them in the `caddy_data` named volume. The ACME
# email is set so LE can reach us about expirations if auto-renewal ever
# breaks.
#
# Zero-downtime deploys: during a `docker rollout` of `frontend` or `api`
# the service briefly has two replicas running behind its Compose DNS
# name. Both upstream blocks below resolve that DNS name on a short
# interval (`dynamic a`) and run an active health probe so Caddy
# includes the new replica as soon as it's ready and drops the old one
# the moment Docker terminates it. 127.0.0.11 is Docker's embedded DNS
# resolver — mandatory inside the Compose network.

{
	email jaapstronks@gmail.com
}

# ---------------------------------------------------------------------------
# Apex — the app itself
# ---------------------------------------------------------------------------
woobuddy.nl {
	encode zstd gzip

	# API goes to FastAPI. Larger body limit so PDF uploads on /api/analyze
	# and /api/export/redact don't get clipped. Client-first means documents
	# travel from the browser to the backend as part of the analyze/export
	# request bodies.
	handle_path /api/* {
		request_body {
			max_size 50MB
		}
		reverse_proxy {
			# `handle_path` strips the matched prefix — put it back so FastAPI
			# sees the original /api/... path that its routers expect.
			rewrite /api{uri}
			dynamic a {
				name api
				port 8000
				refresh 5s
				resolvers 127.0.0.11
			}
			lb_policy round_robin
			health_uri /api/health
			health_interval 5s
			health_timeout 3s
			fail_duration 15s
		}
	}

	# Everything else → SvelteKit
	handle {
		reverse_proxy {
			dynamic a {
				name frontend
				port 3000
				refresh 5s
				resolvers 127.0.0.11
			}
			lb_policy round_robin
			health_uri /health
			health_interval 5s
			health_timeout 3s
			fail_duration 15s
		}
	}

	# Strict transport security — one year, include subdomains, preload-safe.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
}

# ---------------------------------------------------------------------------
# www → apex redirect (301)
# ---------------------------------------------------------------------------
www.woobuddy.nl {
	redir https://woobuddy.nl{uri} permanent
}
