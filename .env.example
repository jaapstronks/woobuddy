# =============================================================================
# WOO Buddy — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# No LLM
# -----------------------------------------------------------------------------
# WOO Buddy runs detection on regex + Deduce + wordlists + structure
# heuristics. There is no LLM anywhere in the codebase, so there are no
# LLM/Ollama settings to configure here. If a future contributor revives a
# local LLM verification pass, see docs/reference/llm-revival.md.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=woobuddy
POSTGRES_PASSWORD=woobuddy
POSTGRES_DB=woobuddy
DATABASE_URL=postgresql+asyncpg://woobuddy:woobuddy@postgres:5432/woobuddy

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# API base URL the browser calls. Match this to your workflow:
#   - Docker Compose (`docker compose up`)       → http://localhost:8100
#   - Bare-metal uvicorn (`uvicorn app.main:app`) → http://localhost:8000
# Both ports are allowed by the frontend CSP, so switching is safe.
PUBLIC_API_URL=http://localhost:8100

# -----------------------------------------------------------------------------
# Lead capture (optional)
# -----------------------------------------------------------------------------
# Needed only if you run the landing-page contact form. Every submission
# fires a transactional email to BREVO_NOTIFICATION_EMAIL so the operator
# sees the message. If the visitor ticks the newsletter checkbox the
# contact is also added to Brevo list BREVO_LIST_ID. Leave BREVO_API_KEY
# empty in local development.
BREVO_API_KEY=
BREVO_LIST_ID=4
BREVO_NOTIFICATION_EMAIL=jaapstronks@gmail.com
# Sender must be verified in the Brevo dashboard, otherwise /v3/smtp/email
# rejects the call with 400.
BREVO_SENDER_EMAIL=noreply@woobuddy.nl
BREVO_SENDER_NAME=WOO Buddy

# -----------------------------------------------------------------------------
# File-picker OAuth apps (#51)
# -----------------------------------------------------------------------------
# WOO Buddy can ingest PDFs directly from SharePoint / OneDrive / Google Drive
# using each provider's in-browser picker. The file is downloaded straight
# from the provider to the reviewer's browser — it never touches our server.
# See docs/self-hosting/file-picker.md for full setup.
#
# Leave a variable blank to hide that provider's button.

# Microsoft Graph File Picker v8
PUBLIC_MS_PICKER_CLIENT_ID=
# Defaults to https://login.microsoftonline.com/common (multi-tenant)
PUBLIC_MS_PICKER_AUTHORITY=

# Google Picker API
PUBLIC_GOOGLE_PICKER_CLIENT_ID=
PUBLIC_GOOGLE_PICKER_API_KEY=
PUBLIC_GOOGLE_PICKER_APP_ID=
