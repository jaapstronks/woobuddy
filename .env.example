# =============================================================================
# WOO Buddy — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# LLM layer (DORMANT)
# -----------------------------------------------------------------------------
# WOO Buddy runs detection on regex + Deduce + wordlists + structure
# heuristics. No LLM is called in the default code path. The Ollama provider
# in backend/app/llm/ is kept in-tree as a parked revival path — see
# backend/app/llm/README.md.
#
# Leave both flags unset (or false) for normal operation. Flip one of them on
# for experimentation and point OLLAMA_BASE_URL at a running local instance.
LLM_TIER2_ENABLED=false
LLM_TIER3_ENABLED=false

# Revival-only — only consulted when an LLM_TIER*_ENABLED flag is true.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_KEEP_ALIVE=-1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=woobuddy
POSTGRES_PASSWORD=woobuddy
POSTGRES_DB=woobuddy
DATABASE_URL=postgresql+asyncpg://woobuddy:woobuddy@postgres:5432/woobuddy

# -----------------------------------------------------------------------------
# MinIO (S3-compatible PDF storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=woobuddy
MINIO_SECRET_KEY=woobuddy-secret
MINIO_BUCKET=documents

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:8000
