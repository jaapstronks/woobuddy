# =============================================================================
# WOO Buddy — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# No LLM
# -----------------------------------------------------------------------------
# WOO Buddy runs detection on regex + Deduce + wordlists + structure
# heuristics. There is no LLM anywhere in the codebase, so there are no
# LLM/Ollama settings to configure here. If a future contributor revives a
# local LLM verification pass, see docs/reference/llm-revival.md.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=woobuddy
POSTGRES_PASSWORD=woobuddy
POSTGRES_DB=woobuddy
DATABASE_URL=postgresql+asyncpg://woobuddy:woobuddy@postgres:5432/woobuddy

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# API base URL the browser calls. Match this to your workflow:
#   - Docker Compose (`docker compose up`)       → http://localhost:8100
#   - Bare-metal uvicorn (`uvicorn app.main:app`) → http://localhost:8000
# Both ports are allowed by the frontend CSP, so switching is safe.
PUBLIC_API_URL=http://localhost:8100

# -----------------------------------------------------------------------------
# Lead capture (optional)
# -----------------------------------------------------------------------------
# Needed only if you run the landing-page signup form and want submissions
# pushed into a Brevo audience list. Leave empty for local development.
BREVO_API_KEY=
BREVO_LIST_ID=4
