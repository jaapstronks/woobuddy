{
	"name": "woobuddy-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"setup:tesseract": "node scripts/download-tesseract-data.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
