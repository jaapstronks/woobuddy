		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/svelte": "^5.3.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@shoelace-style/shoelace": "^2.20.0",
		"fflate": "^0.8.2",
		"lucide-svelte": "^1.0.1",
		"pdfjs-dist": "^5.6.205",
		"tailwindcss": "^4.2.4",
		"tesseract.js": "^7.0.0"
	}
