# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# URL of the FastAPI backend. Two supported workflows:
#   - Bare-metal uvicorn → http://localhost:8000
#   - Docker Compose     → http://localhost:8100
# Both ports are allowed in the frontend CSP, so either works without edits.
PUBLIC_API_URL=http://localhost:8100

# -----------------------------------------------------------------------------
# Site mode
# -----------------------------------------------------------------------------
# "hosted" enables the marketing landing page (headline, demo video, "how it
# works", lead-capture form) and the woobuddy.nl-specific static pages (legal,
# roadmap). Leave unset — or set to anything other than "hosted" — for a
# neutral self-host landing that drops the reviewer straight into the upload
# flow. Forks should keep this unset unless they're rebranding.
PUBLIC_SITE_MODE=

# -----------------------------------------------------------------------------
# Plausible Analytics (self-hosted, cookieless)
# -----------------------------------------------------------------------------
# Leave PUBLIC_PLAUSIBLE_DOMAIN blank to disable analytics entirely — the script
# tag will not be injected and the track() wrapper becomes a no-op. Set both
# values in production to enable.
#
# PUBLIC_PLAUSIBLE_DOMAIN is the site identifier registered in Plausible (the
# public hostname visitors see, e.g. "woobuddy.nl"). PUBLIC_PLAUSIBLE_SRC is
# the URL of the tracker script served by the self-hosted instance.
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=
PUBLIC_PLAUSIBLE_API=

# -----------------------------------------------------------------------------
# File-picker OAuth apps (#51 — client-side only; pickers run in the browser)
# -----------------------------------------------------------------------------
# Leave any variable blank to hide that provider's button. See
# docs/self-hosting/file-picker.md for how to create your own apps.

# Microsoft Graph File Picker v8 — Azure AD / Entra ID app registration
PUBLIC_MS_PICKER_CLIENT_ID=
# Defaults to https://login.microsoftonline.com/common (any work/school or
# personal account). Pin to a tenant ID for single-tenant deployments.
PUBLIC_MS_PICKER_AUTHORITY=

# Google Picker API — Google Cloud project
PUBLIC_GOOGLE_PICKER_CLIENT_ID=
PUBLIC_GOOGLE_PICKER_API_KEY=
PUBLIC_GOOGLE_PICKER_APP_ID=
